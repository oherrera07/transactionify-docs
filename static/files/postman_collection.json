{
  "info": {
    "name": "Transactionify API",
    "description": "A simple payment and account management API.\n\n## Authentication\nAll endpoints require authentication using an API Key passed in the Authorization header:\n```\nAuthorization: APIKey <your-api-key>\n```\n\n## Features\n- Create and manage accounts with different currencies (USD, EUR, GBP)\n- Create payments for accounts\n- Retrieve account balances\n- List transaction history\n\n## Getting Started\n1. Set the `baseUrl` environment variable to your API base URL\n2. Set the `apiKey` environment variable to your API key\n3. Run **Create Account** first — the `accountId` variable will be set automatically via the test script\n4. Use that `accountId` to test payments, balance, and transactions",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "transactionify-api-collection-v1"
  },
  "variable": [],
  "auth": {
    "type": "apikey",
    "apikey": [
      {
        "key": "key",
        "value": "Authorization",
        "type": "string"
      },
      {
        "key": "value",
        "value": "APIKey {{apiKey}}",
        "type": "string"
      },
      {
        "key": "in",
        "value": "header",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Accounts",
      "description": "Account management operations",
      "item": [
        {
          "name": "Create Account (USD)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    if (json.id) {",
                  "        pm.collectionVariables.set('accountId', json.id);",
                  "        console.log('accountId set to:', json.id);",
                  "    }",
                  "}",
                  "",
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response has account id', () => {",
                  "    pm.expect(pm.response.json()).to.have.property('id');",
                  "});",
                  "pm.test('Balance starts at 0.00', () => {",
                  "    pm.expect(pm.response.json().balance.value).to.eql('0.00');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currency\": \"USD\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/accounts",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "accounts"]
            },
            "description": "Creates a new USD account. The returned `id` is automatically saved to the `accountId` collection variable for use in subsequent requests."
          },
          "response": [
            {
              "name": "USD account created",
              "status": "OK",
              "code": 200,
              "header": [{"key": "Content-Type", "value": "application/json"}],
              "body": "{\n  \"id\": \"019a4757-c049-7ea8-a110-2ea110c5a6f8\",\n  \"balance\": {\n    \"value\": \"0.00\",\n    \"currency\": \"USD\"\n  }\n}"
            },
            {
              "name": "400 - Invalid currency",
              "status": "Bad Request",
              "code": 400,
              "header": [{"key": "Content-Type", "value": "application/json"}],
              "body": "{\n  \"message\": \"Invalid currency. Allowed values: USD, EUR, GBP\"\n}"
            },
            {
              "name": "401 - Unauthorized",
              "status": "Unauthorized",
              "code": 401,
              "header": [{"key": "Content-Type", "value": "application/json"}],
              "body": "{\n  \"message\": \"Unauthorized\"\n}"
            }
          ]
        },
        {
          "name": "Create Account (EUR)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Currency is EUR', () => {",
                  "    pm.expect(pm.response.json().balance.currency).to.eql('EUR');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currency\": \"EUR\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/accounts",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "accounts"]
            },
            "description": "Creates a new EUR account."
          },
          "response": [
            {
              "name": "EUR account created",
              "status": "OK",
              "code": 200,
              "header": [{"key": "Content-Type", "value": "application/json"}],
              "body": "{\n  \"id\": \"019a4757-c049-7ea8-a110-2ea110c5a6f8\",\n  \"balance\": {\n    \"value\": \"0.00\",\n    \"currency\": \"EUR\"\n  }\n}"
            }
          ]
        },
        {
          "name": "Create Account (GBP)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Currency is GBP', () => {",
                  "    pm.expect(pm.response.json().balance.currency).to.eql('GBP');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currency\": \"GBP\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/accounts",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "accounts"]
            },
            "description": "Creates a new GBP account."
          },
          "response": [
            {
              "name": "GBP account created",
              "status": "OK",
              "code": 200,
              "header": [{"key": "Content-Type", "value": "application/json"}],
              "body": "{\n  \"id\": \"019a4757-c049-7ea8-a110-2ea110c5a6f8\",\n  \"balance\": {\n    \"value\": \"0.00\",\n    \"currency\": \"GBP\"\n  }\n}"
            }
          ]
        }
        
      ]
    },
    {
      "name": "Payments",
      "description": "Payment creation operations",
      "item": [
        {
          "name": "Create Payment",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Payment has id', () => {",
                  "    pm.expect(pm.response.json()).to.have.property('id');",
                  "});",
                  "pm.test('Type is payment', () => {",
                  "    pm.expect(pm.response.json().type).to.eql('payment');",
                  "});",
                  "pm.test('Status is pending', () => {",
                  "    pm.expect(pm.response.json().status).to.eql('pending');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": {\n    \"value\": \"100.00\",\n    \"currency\": \"USD\"\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/accounts/{{accountId}}/payments",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "accounts", "{{accountId}}", "payments"]
            },
            "description": "Creates a USD payment on the account stored in `{{accountId}}`. Make sure to run **Create Account (USD)** first so the variable is populated."
          },
          "response": [
            {
              "name": "Payment created",
              "status": "OK",
              "code": 200,
              "header": [{"key": "Content-Type", "value": "application/json"}],
              "body": "{\n  \"id\": \"019a4757-c049-7ea8-a110-2ea110c5a6f9\",\n  \"type\": \"payment\",\n  \"amount\": {\n    \"value\": \"100.00\",\n    \"currency\": \"USD\"\n  },\n  \"status\": \"pending\"\n}"
            },
            {
              "name": "400 - Currency mismatch",
              "status": "Bad Request",
              "code": 400,
              "header": [{"key": "Content-Type", "value": "application/json"}],
              "body": "{\n  \"message\": \"Currency does not match account currency\"\n}"
            },
            {
              "name": "404 - Account not found",
              "status": "Not Found",
              "code": 404,
              "header": [{"key": "Content-Type", "value": "application/json"}],
              "body": "{\n  \"message\": \"Account not found\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Balance",
      "description": "Balance retrieval operations",
      "item": [
        {
          "name": "Get Account Balance",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response has balance', () => {",
                  "    pm.expect(pm.response.json()).to.have.property('balance');",
                  "});",
                  "pm.test('Response has date', () => {",
                  "    pm.expect(pm.response.json()).to.have.property('date');",
                  "});",
                  "pm.test('Balance has value and currency', () => {",
                  "    const balance = pm.response.json().balance;",
                  "    pm.expect(balance).to.have.property('value');",
                  "    pm.expect(balance).to.have.property('currency');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/accounts/{{accountId}}/balance",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "accounts", "{{accountId}}", "balance"]
            },
            "description": "Retrieves the current balance for the account in `{{accountId}}`, including the current timestamp."
          },
          "response": [
            {
              "name": "Balance retrieved",
              "status": "OK",
              "code": 200,
              "header": [{"key": "Content-Type", "value": "application/json"}],
              "body": "{\n  \"balance\": {\n    \"value\": \"250.50\",\n    \"currency\": \"USD\"\n  },\n  \"date\": \"2025-11-03T15:13:34.198530Z\"\n}"
            },
            {
              "name": "404 - Account not found",
              "status": "Not Found",
              "code": 404,
              "header": [{"key": "Content-Type", "value": "application/json"}],
              "body": "{\n  \"message\": \"Account not found\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Transactions",
      "description": "Transaction history operations",
      "item": [
        {
          "name": "List Transactions (default)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response has transactions array', () => {",
                  "    pm.expect(pm.response.json().transactions).to.be.an('array');",
                  "});",
                  "pm.test('Response has has_more flag', () => {",
                  "    pm.expect(pm.response.json()).to.have.property('has_more');",
                  "});",
                  "// Save next_cursor if available",
                  "const json = pm.response.json();",
                  "if (json.has_more && json.next_cursor) {",
                  "    pm.collectionVariables.set('nextCursor', json.next_cursor);",
                  "    console.log('nextCursor saved for pagination');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/accounts/{{accountId}}/transactions",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "accounts", "{{accountId}}", "transactions"]
            },
            "description": "Retrieves the first page of transactions (default limit: 20) for the account in `{{accountId}}`. If more pages exist, `next_cursor` is saved to the `nextCursor` variable."
          },
          "response": [
            {
              "name": "Transactions without pagination",
              "status": "OK",
              "code": 200,
              "header": [{"key": "Content-Type", "value": "application/json"}],
              "body": "{\n  \"transactions\": [\n    {\n      \"id\": \"e46ae990-9e59-7afa-bc71-112ac07c97c2\",\n      \"type\": \"payment\",\n      \"amount\": {\n        \"value\": \"100.00\",\n        \"currency\": \"USD\"\n      },\n      \"timestamp\": \"2026-03-09T10:00:00.000000Z\"\n    },\n    {\n      \"id\": \"d1bb6c85-404a-7232-af08-37488a95d20a\",\n      \"type\": \"payment\",\n      \"amount\": {\n        \"value\": \"250.00\",\n        \"currency\": \"USD\"\n      },\n      \"timestamp\": \"2026-03-09T11:30:00.000000Z\"\n    },\n    {\n      \"id\": \"cf15c249-15a1-7357-b866-988aae063cf3\",\n      \"type\": \"refund\",\n      \"amount\": {\n        \"value\": \"50.00\",\n        \"currency\": \"USD\"\n      },\n      \"timestamp\": \"2026-03-09T13:45:00.000000Z\"\n    },\n    {\n      \"id\": \"a34e0103-54eb-7e03-a9b6-fd25beb2bca8\",\n      \"type\": \"payment\",\n      \"amount\": {\n        \"value\": \"500.00\",\n        \"currency\": \"USD\"\n      },\n      \"timestamp\": \"2026-03-09T15:00:00.000000Z\"\n    }\n  ],\n  \"has_more\": false\n}"
            },
            {
              "name": "No transactions",
              "status": "OK",
              "code": 200,
              "header": [{"key": "Content-Type", "value": "application/json"}],
              "body": "{\n  \"transactions\": [],\n  \"has_more\": false\n}"
            }
          ]
        },
        {
          "name": "List Transactions (with limit)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns at most requested limit', () => {",
                  "    pm.expect(pm.response.json().transactions.length).to.be.at.most(5);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/accounts/{{accountId}}/transactions?limit=5",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "accounts", "{{accountId}}", "transactions"],
              "query": [
                {
                  "key": "limit",
                  "value": "5",
                  "description": "Number of transactions per page (1–100)"
                }
              ]
            },
            "description": "Retrieves a custom page size of 5 transactions."
          },
          "response": [
            {
              "name": "Transactions with pagination",
              "status": "OK",
              "code": 200,
              "header": [{"key": "Content-Type", "value": "application/json"}],
              "body": "{\n  \"transactions\": [\n    {\n      \"id\": \"019a4757-c049-7ea8-a110-2ea110c5a6f9\",\n      \"type\": \"payment\",\n      \"amount\": {\n        \"value\": \"100.00\",\n        \"currency\": \"USD\"\n      },\n      \"timestamp\": \"2025-11-03T15:03:54.155792Z\"\n    },\n    {\n      \"id\": \"019a4757-c049-7ea8-a110-2ea110c5a700\",\n      \"type\": \"payment\",\n      \"amount\": {\n        \"value\": \"50.00\",\n        \"currency\": \"USD\"\n      },\n      \"timestamp\": \"2025-11-03T15:05:57.113136Z\"\n    }\n  ],\n  \"has_more\": true,\n  \"next_cursor\": \"eyJQSyI6IkFDQ09VTlQjMDE5YTQ3NTctYzA0OS03ZWE4LWExMTAtMmVhMTEwYzVhNmY4IiwiU0siOiJUUkFOU0FDVElPTiMwMTlhNDc1Ny1jMDQ5LTdlYTgtYTExMC0yZWExMTBjNWE2ZjkifQ==\"\n}"
            }
          ]
        },
        {
          "name": "List Transactions (next page with cursor)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response has transactions array', () => {",
                  "    pm.expect(pm.response.json().transactions).to.be.an('array');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/accounts/{{accountId}}/transactions?cursor={{nextCursor}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "accounts", "{{accountId}}", "transactions"],
              "query": [
                {
                  "key": "cursor",
                  "value": "{{nextCursor}}",
                  "description": "Pagination cursor saved from the previous List Transactions response"
                }
              ]
            },
            "description": "Fetches the next page using the `{{nextCursor}}` variable saved by **List Transactions (default)**. Run that request first."
          },
          "response": [
            {
              "name": "Transactions with next cursor",
              "status": "OK",
              "code": 200,
              "header": [{"key": "Content-Type", "value": "application/json"}],
              "body": "{\n  \"transactions\": [\n    {\n      \"id\": \"019a4757-c049-7ea8-a110-2ea110c5a6f9\",\n      \"type\": \"payment\",\n      \"amount\": {\n        \"value\": \"100.00\",\n        \"currency\": \"USD\"\n      },\n      \"timestamp\": \"2025-11-03T15:03:54.155792Z\"\n    },\n    {\n      \"id\": \"019a4757-c049-7ea8-a110-2ea110c5a700\",\n      \"type\": \"payment\",\n      \"amount\": {\n        \"value\": \"50.00\",\n        \"currency\": \"USD\"\n      },\n      \"timestamp\": \"2025-11-03T15:05:57.113136Z\"\n    }\n  ],\n  \"has_more\": true,\n  \"next_cursor\": \"eyJQSyI6IkFDQ09VTlQjMDE5YTQ3NTctYzA0OS03ZWE4LWExMTAtMmVhMTEwYzVhNmY4IiwiU0siOiJUUkFOU0FDVElPTiMwMTlhNDc1Ny1jMDQ5LTdlYTgtYTExMC0yZWExMTBjNWE2ZjkifQ==\"\n}"
            }
          ]
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "accountId",
      "value": "",
      "type": "string",
      "description": "Auto-populated by the 'Create Account' request test script. You can also set this manually to an existing account UUID."
    },
    {
      "key": "nextCursor",
      "value": "",
      "type": "string",
      "description": "Auto-populated by the 'List Transactions (default)' request when has_more=true. Used by the paginated transactions request."
    }
  ]
}
